{
  "settings": {
    "index": {
      "knn": true,
      "knn.algo_param.ef_search": 100,
      "number_of_shards": 1,
      "number_of_replicas": 1
    }
  },
  "mappings": {
    "properties": {

      "embedding": {
        "type": "knn_vector",
        "dimension": 384,
        "method": {
          "name": "hnsw",
          "space_type": "cosinesimil",
          "engine": "lucene",
          "parameters": {
            "ef_construction": 128,
            "m": 16
          }
        }
      },

      "object_key": {
        "type": "keyword"
      },

      "bucket": {
        "type": "keyword"
      },

      "filename": {
        "type": "keyword",
        "fields": {
          "text": {
            "type": "text",
            "analyzer": "standard"
          }
        }
      },

      "content_type": {
        "type": "keyword"
      },

      "doc_type": {
        "type": "keyword"
      },

      "text": {
        "type": "text",
        "analyzer": "standard"
      },

      "chunk_index": {
        "type": "integer"
      },

      "total_chunks": {
        "type": "integer"
      },

      "start_char": {
        "type": "integer"
      },

      "end_char": {
        "type": "integer"
      },

      "orig_width": {
        "type": "integer"
      },

      "orig_height": {
        "type": "integer"
      },

      "file_size_bytes": {
        "type": "long"
      },

      "ingested_at": {
        "type": "date",
        "format": "strict_date_time"
      },

      "tika_metadata": {
        "type": "object",
        "enabled": false
      }

    }
  }
}
