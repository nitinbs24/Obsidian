# MinIO Instance Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_VOLUMES=/data
MINIO_SITE_NAME=obsidian-minio

# MinIO Endpoints
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Bucket Configuration
MINIO_DEFAULT_BUCKET=uploads

# Kafka Notification Target
MINIO_NOTIFY_KAFKA_ENABLE_1=on
MINIO_NOTIFY_KAFKA_BROKERS_1=my-cluster-kafka-bootstrap.kafka.svc.cluster.local:9092
MINIO_NOTIFY_KAFKA_TOPIC_1=file-upload-events
